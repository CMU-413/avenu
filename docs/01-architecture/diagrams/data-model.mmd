erDiagram

    USER {
        ObjectId id PK
        int optixId UK
        boolean isAdmin
        string fullname
        string email UK
        string phone
        ObjectId[] teamIds FK
        enum[] notifPrefs "email | text"
        datetime createdAt
        datetime updatedAt
    }

    TEAM {
        ObjectId id PK
        int optixId UK
        string name
        datetime createdAt
        datetime updatedAt
    }

    MAILBOX {
        ObjectId id PK
        enum type "user | team"
        ObjectId refId FK
        string displayName
        datetime createdAt
        datetime updatedAt
    }

    MAIL {
        ObjectId id PK
        ObjectId mailboxId FK
        datetime date
        enum type "letter | package"
        string receiverName "optional"
        string senderInfo "optional"
        boolean isPromotional "optional; omitted when false"
        int count "optional legacy N pieces"
        datetime createdAt
        datetime updatedAt
    }

    MAIL_REQUEST {
        ObjectId id PK
        ObjectId memberId FK
        ObjectId mailboxId FK
        string expectedSender "optional"
        string description "optional"
        string startDate "optional YYYY-MM-DD"
        string endDate "optional YYYY-MM-DD"
        enum status "ACTIVE | CANCELLED | RESOLVED"
        datetime resolvedAt "optional"
        ObjectId resolvedBy FK "optional"
        enum lastNotificationStatus "SENT | SKIPPED | FAILED | null"
        datetime lastNotificationAt "optional"
        datetime createdAt
        datetime updatedAt
    }

    NOTIFICATION_LOG {
        ObjectId id PK
        ObjectId userId FK
        enum type "weekly-summary | mail-arrived"
        datetime weekStart
        enum status "sent | skipped | failed"
        enum reason "already_sent | opted_out | empty_summary | user_not_found | all_channels_failed"
        string triggeredBy
        datetime sentAt
        datetime createdAt
        string errorMessage
    }

    OCR_JOB {
        ObjectId id PK
        ObjectId createdBy FK
        string date "YYYY-MM-DD"
        enum status "processing | processed | failed | audited"
        int totalCount
        int completedCount
        datetime createdAt
        datetime updatedAt
    }

    OCR_QUEUE_ITEM {
        ObjectId id PK
        ObjectId jobId FK
        int index
        enum status "pending | completed | failed | confirmed | deleted"
        string receiverName "optional"
        string senderInfo "optional"
        enum type "letter | package"
        string rawText "optional"
        string error "optional"
        ObjectId mailboxId FK "optional"
        ObjectId fileId FK "optional; legacy GridFS reference, nullable for new uploads"
        string imagePath "optional; relative path under IMAGE_STORE_DIR volume"
        boolean isPromotional "default false; gated by FEATURE_PROMO_CLASSIFICATION"
        datetime confirmedAt "optional"
        datetime createdAt
        datetime updatedAt
    }

    ADMIN_MAGIC_LINK {
        string tokenId PK
        ObjectId userId FK
        int exp "unix"
        datetime expiresAt
        object metadata
        boolean consumed
        datetime createdAt
        datetime updatedAt
    }

    %% Relationships (MongoDB: refs are ObjectIds; uniqueness via indexes, not FK enforcement)

    USER }o--o{ TEAM : "teamIds"

    USER ||--|| MAILBOX : "type=user refId"
    TEAM ||--|| MAILBOX : "type=team refId"

    MAILBOX ||--o{ MAIL : contains
    USER ||--o{ MAIL_REQUEST : declares
    MAILBOX ||--o{ MAIL_REQUEST : scoped_to

    USER ||--o{ NOTIFICATION_LOG : notified_as

    USER ||--o{ OCR_JOB : creates
    OCR_JOB ||--o{ OCR_QUEUE_ITEM : items

    USER ||--o{ ADMIN_MAGIC_LINK : "sign-in token"

    %% Confirming a queue item creates a MAIL row; no stored FK from mail back to OCR_QUEUE_ITEM
