erDiagram

    USER {
        ObjectId id PK
        int optixId
        boolean isAdmin
        string fullname
        string email
        string phone
        ObjectId[] teamIds FK
        enum[] notifPrefs "email | text"
    }

    TEAM {
        ObjectId id PK
        int optixId
        string name
    }

    MAILBOX {
        ObjectId id PK
        enum type "user | team"
        ObjectId refId FK
        string displayName
    }

    MAIL {
        ObjectId id PK
        ObjectId mailboxId FK
        datetime date
        enum type "letter | package"
        int count
    }

    MAIL_REQUEST {
        ObjectId id PK
        ObjectId memberId FK
        ObjectId mailboxId FK
        string expectedSender
        string description
        datetime startDate
        datetime endDate
        enum status "ACTIVE | CANCELLED | RESOLVED"
        datetime resolvedAt
        ObjectId resolvedBy FK
        enum lastNotificationStatus "SENT | SKIPPED | FAILED"
        datetime lastNotificationAt
    }

    NOTIFICATION_LOG {
        ObjectId id PK
        ObjectId userId FK
        enum type "weekly-summary | mail-arrived"
        datetime weekStart
        enum status "sent | skipped | failed"
        enum reason "already_sent | opted_out | empty_summary | user_not_found | all_channels_failed"
        string triggeredBy
        datetime sentAt
        datetime createdAt
        string errorMessage
    }

    %% Relationships
    USER }|--o{ TEAM : belongs_to

    USER ||--|| MAILBOX : owns
    TEAM ||--|| MAILBOX : owns

    MAILBOX ||--o{ MAIL : contains
    USER ||--o{ MAIL_REQUEST : declares
    MAILBOX ||--o{ MAIL_REQUEST : scoped_to
