flowchart LR

    %% ===== External Actors =====
    Users["Users<br>Web Browser"]

    Optix["Optix API<br>External SaaS"]
    EmailProvider["Email Provider<br>External Service"]
    SMSProvider["SMS Provider<br>External Service"]
    MongoDB["MongoDB Atlas<br>Managed Cloud Database"]

    %% ===== Host =====
    subgraph Host["Production Linux Host"]

        Nginx["nginx<br>Reverse Proxy<br>Routes /mail, /mail/api, /mail/grafana"]

        subgraph Compose["Docker Compose Stack"]

            subgraph Network["Internal Docker Network"]

                Frontend["frontend container<br>React SPA<br>Port 18080"]

                Backend["backend container<br>Flask API + Tesseract OCR<br>Port 18000"]

                Scheduler["scheduler container<br>Cron job runner"]

                Prometheus["prometheus container<br>Metrics collection"]

                Grafana["grafana container<br>Monitoring dashboards"]

            end

            OCRVolume["ocr-staging volume<br>Bind-mounted image staging"]

        end
    end

    %% ===== User Traffic =====
    Users -->|"HTTPS"| Nginx

    Nginx -->|"/mail"| Frontend
    Nginx -->|"/mail/api"| Backend
    Nginx -->|"/mail/grafana"| Grafana

    %% ===== Internal Communication =====
    Frontend -->|"JSON/HTTP"| Backend
    Scheduler -->|"HTTP via Docker DNS"| Backend

    %% ===== OCR Staging =====
    Backend -->|"Reads/writes staged mail photos"| OCRVolume

    %% ===== Monitoring =====
    Prometheus -->|"Scrapes metrics"| Backend
    Grafana -->|"Queries metrics"| Prometheus

    %% ===== External Integrations =====
    Backend -->|"MongoDB/TLS"| MongoDB
    Backend -->|"JSON/HTTPS"| Optix
    Backend -->|"HTTPS"| EmailProvider
    Backend -->|"HTTPS"| SMSProvider
