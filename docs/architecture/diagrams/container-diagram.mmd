Member["Avenu Member<br>[Person]"]

Admin["Avenu Admin<br>[Person]"]

%% =============================
%% SYSTEM BOUNDARY
%% =============================

subgraph Avenu["Avenu Mail System"]

    Frontend["Frontend<br>[Container: React, JavaScript]<br>Single-page application used by admins and members"]

    Backend["Backend<br>[Container: Python, Flask]<br>Implements application business logic and coordinates persistence and external services"]

    Scheduler["Scheduler<br>[Container: Python Job Runner]<br>Executes time-based jobs by invoking the Backend API"]

    Database["Database<br>[Container: MongoDB]<br>Stores users, teams, mailboxes, mail entries,<br>and notification preferences"]

end

%% =============================
%% EXTERNAL SYSTEMS
%% =============================

Optix["Optix<br>Authoritative source for user and team identity"]

EmailProvider["Email Provider<br>Sends weekly summary emails"]

OCRProvider["OCR Provider<br>Extracts mailbox identifiers from images"]

%% =============================
%% RELATIONSHIPS
%% =============================

Member -->|"Views mail totals and weekly summaries from"| Frontend
Admin -->|"Logs and manages incoming mail using"| Frontend

Frontend -->|"Makes API requests to"| Backend

Scheduler -->|"Makes API requests to"| Backend

Backend -->|"Reads from and writes to"| Database

Backend -->|"Synchronizes identity data using"| Optix
Backend -->|"Sends summary emails using"| EmailProvider
Backend -->|"Performs OCR extraction using"| OCRProvider
