# Local development defaults
MONGO_URI=mongodb://localhost:27017/avenu_db
DB_NAME=avenu_db

SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=avenu_session
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_PARTITIONED=false
AUTHENTICATED_SESSION_TTL_SECONDS=43200

# Comma-separated allowed browser origins for the backend CORS policy.
FRONTEND_ORIGINS=http://localhost:8080
SCHEDULER_INTERNAL_TOKEN=replace-with-a-shared-internal-token

AUTH_MAGIC_LINK_BASE_URL=http://localhost:8080/mail
AUTH_MAGIC_LINK_PATH=/
AUTH_MAGIC_LINK_EXPIRY_SECONDS=900
# AUTH_MAGIC_LINK_SECRET=

LOGIN_RATE_LIMIT_IP_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_IP_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_EMAIL_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_EMAIL_MAX_ATTEMPTS=5

MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_EMAIL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

VITE_BASE_PATH=/mail/
VITE_API_BASE_URL=/mail/api

BACKEND_API_URL=http://backend:8000
SCHEDULER_CRON=0 8 * * 1
SCHEDULER_TIMEZONE=America/New_York
SCHEDULER_TICK_SECONDS=20

# Production-only compose helpers for docker-compose-prod.yml
IMAGE_NAMESPACE=chunkitw
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=https://hub.avenuworkspaces.com/mail/grafana
PROMETHEUS_DATA_DIR=/mnt/Main/other/PrometheusMail/
PROMETHEUS_CONFIG_DIR=/mnt/Main/other/PrometheusMailEtc/
GRAFANA_DATA_DIR=/mnt/Main/other/GrafanaMail/
